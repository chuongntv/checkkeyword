{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "../dist/worker",
    "rootDir": "..",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../*"]
    },
    "baseUrl": ".."
  },
  "include": ["./**/*.ts", "../lib/**/*.ts", "../models/**/*.ts"],
  "exclude": ["../node_modules"]
}
