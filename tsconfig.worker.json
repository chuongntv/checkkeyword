{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./worker-dist",
    "rootDir": ".",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["worker/**/*", "lib/**/*", "models/**/*", "types/**/*"],
  "exclude": ["node_modules", ".next", "app"]
}
